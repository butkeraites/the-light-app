# ── the-light-app · .gitignore ───────────────────────────────────────────────
# Regras: offline-first / BYOK. Segredos NUNCA entram no git.
# O bloco de verificação da F0.1 procura por: node_modules, target, bindings,
# secrets e .env neste arquivo.

# ── Node / JS / Expo ─────────────────────────────────────────────────────────
node_modules/
.expo/
dist/
*.tsbuildinfo
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Rust ─────────────────────────────────────────────────────────────────────
# Artefatos de build (qualquer crate: core/target, etc.)
**/target/
**/*.rs.bk
Cargo.lock.orig

# ── Bindings gerados ─────────────────────────────────────────────────────────
# bindings/ guarda apenas código GERADO por ferramenta (ubrn/uniffi). Não
# versionar o conteúdo gerado; manter só o placeholder do diretório.
/bindings/*
!/bindings/.gitkeep

# ── Caminho WEB / WASM (F0.6b) — artefatos GERADOS ───────────────────────────
# wasm-crate wrapper gerado pelo `ubrn build web` (rust_modules/wasm/).
/rust_modules/
# .ts web + saída wasm-bindgen (index.js / index_bg.wasm / *.d.ts) e o barrel
# index.web.ts — todos GERADOS. O glue hand-written de app/web/ (versionado) fica
# diretamente em app/web/, NÃO sob generated/.
/app/web/generated/

# ── Caminho iOS NATIVO (F0.7) — artefatos GERADOS ────────────────────────────
# A RN turbo-module library iOS é GERADA na raiz pelo `ubrn build ios`
# (scripts/gen-bindings-ios.sh): glue Obj-C++/C++/TS, xcframework e podspec. A
# raiz é a "library package" que o app autolinka — tudo aqui é gerado/ignorado.
/ios/
/cpp/
/src/
/TheLightAppCoreFramework.xcframework/
# Glob (não só o nome exato): o file-provider (iCloud) sob ~/Documents pode criar
# duplicatas " 2" (ex.: `TheLightAppCore 2.podspec`) de artefatos gerados na raiz.
/TheLightAppCore*.podspec
# Cópia da glue JS p/ dentro de app/ (resolução local do Metro/tsc; ver gen script).
/app/web/native-generated/
# Projeto iOS do prebuild do Expo + CocoaPods (gerados por `expo prebuild`/`pod install`).
/app/ios/

# ── Caminho ANDROID NATIVO (F0.8) — artefatos GERADOS ────────────────────────
# A RN turbo-module library Android é GERADA na raiz pelo `ubrn build android`
# (scripts/gen-bindings-android.sh): módulo Gradle (build.gradle), CMakeLists.txt,
# cpp-adapter.cpp, AndroidManifest(.New).xml, Kotlin (Module/Package), jniLibs/<abi>/
# (.so/.a) e android/generated. A raiz é a "library package" que o app autolinka —
# tudo aqui é gerado/ignorado. (Se um build.gradle hand-written for necessário,
# versioná-lo com exceção dirigida, p.ex. `!/android/build.gradle`.)
/android/
# Projeto Android do prebuild do Expo (gerado por `expo prebuild -p android`).
/app/android/
# Caches/saídas de build Gradle e config local do SDK (qualquer subdir).
**/build/
**/.gradle/
local.properties

# ── Banco bíblico COMPLETO (F1.1) — artefato de BUILD gerado por script ───────
# `assets/data/bible.sqlite` (KJV + Almeida 1911, ~27 MB) é GERADO por
# `scripts/gen-bible-db.sh` rodando o `xtask import` canônico do the-light (rev
# pinado 8f66004). É um artefato de build reprodutível (como bindings/, rust_modules/),
# NÃO versionado — ver ADR-0013. (O `sample.sqlite` ~128 KB da F0.9 PERMANECE
# VERSIONADO — NÃO ignorar; por isso o alvo abaixo é específico de bible.sqlite.)
/assets/data/bible.sqlite
/assets/data/bible.sqlite-wal
/assets/data/bible.sqlite-shm
/assets/data/bible.sqlite-journal
# Subset de LEITURA (F1.3/ADR-0014): KJV+Almeida de Gênesis/Salmos/João, ~1.8 MB,
# DERIVADO do bible.sqlite por `scripts/gen-reading-sample-db.sh` (texto verbatim
# do store). É o asset empacotado no app nativo (copiado p/ path gravável no 1º
# boot). Artefato de BUILD reprodutível, NÃO versionado — como o bible.sqlite. O
# SYMLINK app/assets/data/reading-sample.sqlite (dentro do projectRoot p/ o Metro)
# É versionado: a regra abaixo é anchorada à raiz, não casa o symlink em app/.
/assets/data/reading-sample.sqlite
/assets/data/reading-sample.sqlite-wal
/assets/data/reading-sample.sqlite-shm
/assets/data/reading-sample.sqlite-journal
# Cache de dev/build: datasets brutos JSON baixados (seed-dir) + CARGO_TARGET_DIR
# do xtask (fora do checkout do the-light). SEMPRE ignorado.
/.cache/

# ── Segredos (BYOK) — chaves de IA jamais no git nem em logs ──────────────────
secrets.toml
.env
.env.*
*.key
*.pem
*.keystore
*.p8
*.p12
*.mobileprovision

# ── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
