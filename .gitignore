# ── the-light-app · .gitignore ───────────────────────────────────────────────
# Regras: offline-first / BYOK. Segredos NUNCA entram no git.
# O bloco de verificação da F0.1 procura por: node_modules, target, bindings,
# secrets e .env neste arquivo.

# ── Node / JS / Expo ─────────────────────────────────────────────────────────
node_modules/
.expo/
dist/
*.tsbuildinfo
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Rust ─────────────────────────────────────────────────────────────────────
# Artefatos de build (qualquer crate: core/target, etc.)
**/target/
**/*.rs.bk
Cargo.lock.orig

# ── Bindings gerados ─────────────────────────────────────────────────────────
# bindings/ guarda apenas código GERADO por ferramenta (ubrn/uniffi). Não
# versionar o conteúdo gerado; manter só o placeholder do diretório.
/bindings/*
!/bindings/.gitkeep

# ── Caminho WEB / WASM (F0.6b) — artefatos GERADOS ───────────────────────────
# wasm-crate wrapper gerado pelo `ubrn build web` (rust_modules/wasm/).
/rust_modules/
# .ts web + saída wasm-bindgen (index.js / index_bg.wasm / *.d.ts) e o barrel
# index.web.ts — todos GERADOS. O glue hand-written de app/web/ (versionado) fica
# diretamente em app/web/, NÃO sob generated/.
/app/web/generated/

# ── Caminho iOS NATIVO (F0.7) — artefatos GERADOS ────────────────────────────
# A RN turbo-module library iOS é GERADA na raiz pelo `ubrn build ios`
# (scripts/gen-bindings-ios.sh): glue Obj-C++/C++/TS, xcframework e podspec. A
# raiz é a "library package" que o app autolinka — tudo aqui é gerado/ignorado.
/ios/
/cpp/
/src/
/TheLightAppCoreFramework.xcframework/
/TheLightAppCore.podspec
# Cópia da glue JS p/ dentro de app/ (resolução local do Metro/tsc; ver gen script).
/app/web/native-generated/
# Projeto iOS do prebuild do Expo + CocoaPods (gerados por `expo prebuild`/`pod install`).
/app/ios/

# ── Segredos (BYOK) — chaves de IA jamais no git nem em logs ──────────────────
secrets.toml
.env
.env.*
*.key
*.pem
*.keystore
*.p8
*.p12
*.mobileprovision

# ── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
